# Google Cloud Configuration
GCP_PROJECT_ID=your-project-id
GCP_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json

# BigQuery Configuration
BIGQUERY_DATASET=fintrack_analytics
BIGQUERY_STAGING_DATASET=fintrack_staging
BIGQUERY_LOCATION=US

# Prefect Configuration
PREFECT_API_URL=http://localhost:4200/api
PREFECT_API_KEY=your-prefect-api-key
PREFECT_HOME=/root/.prefect

# Dashboard Configuration
DASH_PORT=8050
DASH_HOST=0.0.0.0
DASH_DEBUG=True
DASH_DEV_TOOLS_ENABLED=True

# Data Refresh Configuration
REFRESH_INTERVAL_MINUTES=15
REFRESH_HOUR_UTC=0
REFRESH_MINUTE_UTC=0

# API Keys & Credentials
STRIPE_API_KEY=sk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_LIVE_MODE=false

SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CLIENT_ID=your-client-id
SALESFORCE_CLIENT_SECRET=your-client-secret
SALESFORCE_USERNAME=your-username@example.com
SALESFORCE_PASSWORD=your-password

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_CHURN_PREDICTION=true
ENABLE_DATA_QUALITY_CHECKS=true
ENABLE_RETENTION_COHORTS=true

# Notification Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERT_EMAIL=alerts@example.com

# Environment
ENVIRONMENT=development
DEBUG=True
